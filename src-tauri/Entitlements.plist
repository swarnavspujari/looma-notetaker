<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened-runtime entitlements applied when the bundle is codesigned
       (Developer ID in CI). Without audio-input, a hardened-runtime app is
       denied microphone/system-audio capture even after the user clicks Allow. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
